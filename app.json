{
  "expo": {
    "name": "Forsa",
    "slug": "forsa",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "forsa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "notification": {
      "icon": "./assets/images/notification-icon.png",
      "color": "#FFD000",
      "androidMode": "default",
      "androidCollapsedTitle": "فرصة"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.replit.forsa",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "نحتاج الوصول للكاميرا لتصوير إيصال الدفع",
        "NSPhotoLibraryUsageDescription": "نحتاج الوصول لمعرض الصور لاختيار إيصال الدفع أو صورة المنتج",
        "UIRequiredDeviceCapabilities": [
          "arm64"
        ],
        "WKCompanionAppBundleIdentifier": "",
        "UIDeviceFamily": [
          1
        ]
      }
    },
    "android": {
      "package": "com.forsa",
      "googleServicesFile": "./google-services.json",
      "versionCode": 2,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#7C3AED",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FFD000",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "نحتاج الوصول لمعرض الصور لاختيار إيصال الدفع أو صورة المنتج",
          "cameraPermission": "نحتاج الوصول للكاميرا لتصوير إيصال الدفع",
          "android": {
            "useAndroidPhotoPicker": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "e753d7dd-1651-4cc5-ae69-b77ba5629277"
      }
    }
  }
}
