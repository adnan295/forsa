{
  "expo": {
    "name": "Forsa",
    "slug": "forsa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "forsa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.forsa",
      "infoPlist": {
        "NSCameraUsageDescription": "نحتاج الوصول للكاميرا لتصوير إيصال الدفع",
        "NSPhotoLibraryUsageDescription": "نحتاج الوصول لمعرض الصور لاختيار إيصال الدفع أو صورة المنتج",
        "UIRequiredDeviceCapabilities": ["arm64"],
        "WKCompanionAppBundleIdentifier": "",
        "UIDeviceFamily": [1]
      }
    },
    "android": {
      "package": "com.forsa",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "READ_MEDIA_IMAGES"],
      "adaptiveIcon": {
        "backgroundColor": "#7C3AED",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "نحتاج الوصول لمعرض الصور لاختيار إيصال الدفع أو صورة المنتج",
          "cameraPermission": "نحتاج الوصول للكاميرا لتصوير إيصال الدفع"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
